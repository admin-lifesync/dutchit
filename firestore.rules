rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ----------------------------------------------------------------------
    // Users
    // Each user can read/write only their own profile document.
    // ----------------------------------------------------------------------
    match /users/{uid} {
      allow read, write: if isSelf(uid);
    }

    // ----------------------------------------------------------------------
    // Groups
    // - read:   any current member of the group
    // - create: any signed-in user (must include themselves as the only admin)
    // - update: rule branches below — admins, self-leave, member bookkeeping,
    //           or self-join (gated by group join policy / approved request)
    // - delete: only group admins
    //
    // Membership lookups use the denormalized memberIds / adminIds arrays.
    // ----------------------------------------------------------------------
    match /groups/{groupId} {

      function group()      { return resource.data; }
      function nextGroup()  { return request.resource.data; }
      function isMember()   { return isSignedIn() && (request.auth.uid in group().memberIds); }
      function isAdmin()    { return isSignedIn() && (request.auth.uid in group().adminIds); }

      // Default join policy for legacy groups without the field.
      function effectivePolicy() {
        return group().get('joinPolicy', 'open');
      }

      function approvedRequestExistsForCaller() {
        // Returns true iff the caller owns an `approved` join request for
        // this group. Used to gate self-add for admin/member-approval flows.
        return exists(/databases/$(database)/documents/groups/$(groupId)/joinRequests/$(request.auth.uid))
          && get(/databases/$(database)/documents/groups/$(groupId)/joinRequests/$(request.auth.uid)).data.status == 'approved';
      }

      allow read: if isMember();

      allow create: if isSignedIn()
        && nextGroup().createdBy == request.auth.uid
        && nextGroup().memberIds.size() == 1
        && nextGroup().memberIds[0] == request.auth.uid
        && nextGroup().adminIds.size() == 1
        && nextGroup().adminIds[0] == request.auth.uid;

      allow update: if
        // 1) Admin can update anything except ownership.
        (
          isAdmin()
          && nextGroup().createdBy == group().createdBy
        )

        // 2) Self-leave: caller (a member) drops themselves and nothing else.
        || (
          isMember()
          && nextGroup().createdBy == group().createdBy
          && nextGroup().memberIds.size() == group().memberIds.size() - 1
          && !(request.auth.uid in nextGroup().memberIds)
          && !(request.auth.uid in nextGroup().adminIds)
          && group().memberIds.hasAll(nextGroup().memberIds)
        )

        // 3) Member-driven bookkeeping update. An existing member may bump
        //    counters/timestamps that change as a side-effect of adding,
        //    editing, deleting expenses, or recording settlements. They
        //    cannot touch metadata, members, admins, or join settings.
        || (
          isMember()
          && nextGroup().createdBy == group().createdBy
          && nextGroup().name == group().name
          && nextGroup().description == group().description
          && nextGroup().imageURL == group().imageURL
          && nextGroup().currency == group().currency
          && nextGroup().memberIds == group().memberIds
          && nextGroup().adminIds == group().adminIds
          && nextGroup().members == group().members
          && nextGroup().get('inviteCode', '') == group().get('inviteCode', '')
          && nextGroup().get('joinPolicy', 'open') == group().get('joinPolicy', 'open')
        )

        // 4) Self-join: a NON-member adds themselves as a regular member.
        //    Allowed only when:
        //      - group is `open`, OR
        //      - the caller owns an `approved` join-request doc.
        //    The caller cannot promote themselves to admin or change any
        //    group metadata in the same write.
        || (
          isSignedIn()
          && !(request.auth.uid in group().memberIds)
          && (request.auth.uid in nextGroup().memberIds)
          && nextGroup().memberIds.size() == group().memberIds.size() + 1
          && nextGroup().memberIds.hasAll(group().memberIds)
          && nextGroup().adminIds == group().adminIds
          && nextGroup().createdBy == group().createdBy
          && nextGroup().name == group().name
          && nextGroup().description == group().description
          && nextGroup().imageURL == group().imageURL
          && nextGroup().currency == group().currency
          && nextGroup().expenseCount == group().expenseCount
          && nextGroup().totalSpent == group().totalSpent
          && nextGroup().get('inviteCode', '') == group().get('inviteCode', '')
          && nextGroup().get('joinPolicy', 'open') == group().get('joinPolicy', 'open')
          && (effectivePolicy() == 'open' || approvedRequestExistsForCaller())
        );

      allow delete: if isAdmin();

      // ------------------------------------------------------------------
      // Expenses subcollection
      // ------------------------------------------------------------------
      match /expenses/{expenseId} {
        function parentGroup() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data;
        }
        function memberOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().memberIds);
        }
        function adminOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().adminIds);
        }

        allow read: if memberOfParent();

        allow create: if memberOfParent()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.groupId == groupId;

        allow update: if memberOfParent()
          && (resource.data.createdBy == request.auth.uid || adminOfParent());

        allow delete: if memberOfParent()
          && (resource.data.createdBy == request.auth.uid || adminOfParent());
      }

      // ------------------------------------------------------------------
      // Settlements subcollection
      // ------------------------------------------------------------------
      match /settlements/{settlementId} {
        function parentGroup() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data;
        }
        function memberOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().memberIds);
        }
        function adminOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().adminIds);
        }

        allow read: if memberOfParent();
        allow create: if memberOfParent()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.groupId == groupId;
        allow update, delete: if memberOfParent()
          && (resource.data.createdBy == request.auth.uid || adminOfParent());
      }

      // ------------------------------------------------------------------
      // Activity log subcollection — append-only
      // ------------------------------------------------------------------
      match /activity/{activityId} {
        function parentGroup() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data;
        }
        function memberOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().memberIds);
        }
        function adminOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().adminIds);
        }

        allow read: if memberOfParent();
        allow create: if memberOfParent()
          && request.resource.data.actorUid == request.auth.uid;
        // Activity entries are immutable — only admins can clean them up.
        allow update: if false;
        allow delete: if adminOfParent();
      }

      // ------------------------------------------------------------------
      // Join requests subcollection
      // - read:   own request, OR any group member (so admins/members can
      //           review pending requests)
      // - create: any signed-in user, only as themselves, only as 'pending'
      // - update: only an approver can flip the status. Approver = admin
      //           always; member if joinPolicy == 'member-approval'.
      //           Approver may also reset to 'pending' (no-op cleanup).
      // - delete: the requester themselves (cancel) or any admin.
      // ------------------------------------------------------------------
      match /joinRequests/{requesterUid} {
        function parentGroup() {
          return get(/databases/$(database)/documents/groups/$(groupId)).data;
        }
        function isMemberOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().memberIds);
        }
        function isAdminOfParent() {
          return isSignedIn() && (request.auth.uid in parentGroup().adminIds);
        }
        function parentPolicy() {
          return parentGroup().get('joinPolicy', 'open');
        }
        function isApprover() {
          return isAdminOfParent()
            || (parentPolicy() == 'member-approval' && isMemberOfParent());
        }

        allow read: if isSelf(requesterUid) || isMemberOfParent();

        allow create: if isSelf(requesterUid)
          && request.resource.data.uid == requesterUid
          && request.resource.data.status == 'pending';

        allow update: if isApprover()
          && request.resource.data.uid == resource.data.uid
          && (
            request.resource.data.status == 'approved'
            || request.resource.data.status == 'rejected'
          );

        allow delete: if isSelf(requesterUid) || isAdminOfParent();
      }
    }

    // ----------------------------------------------------------------------
    // Invitations (public lookup, one per trip)
    // - read:   any signed-in user (needed to render `/invite/<code>`)
    // - create: only an admin of the target group, and only by themselves
    // - update: only an admin of the target group (e.g. join-policy sync)
    // - delete: only an admin of the target group (rotate / clean up)
    // ----------------------------------------------------------------------
    match /invitations/{code} {
      function targetGroup() {
        return get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data;
      }
      function existingGroup() {
        return get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data;
      }

      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (request.auth.uid in targetGroup().adminIds);

      allow update: if isSignedIn()
        && resource.data.groupId == request.resource.data.groupId
        && (request.auth.uid in existingGroup().adminIds);

      allow delete: if isSignedIn()
        && (request.auth.uid in existingGroup().adminIds);
    }
  }
}
